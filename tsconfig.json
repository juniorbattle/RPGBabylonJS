{
  "compilerOptions": {
    "target":           "ES2020",
    "module":           "ESNext",
    "moduleResolution": "bundler",
    "lib":              ["ES2020", "DOM"],
    "strict":           true,
    "noImplicitAny":    true,
    "strictNullChecks": true,
    "esModuleInterop":  true,
    "resolveJsonModule":true,
    "outDir":           "./dist",
    "rootDir":          "./src",
    "sourceMap":        true,
    "declaration":      false,
    "experimentalDecorators": true,
    "types": ["node"]
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "src/**/*.patch.ts"]
}
